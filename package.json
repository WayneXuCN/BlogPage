{
    "name": "academic-blog",
    "version": "1.0.0",
    "description": "A feature-rich academic blog built with Astro 5, React 19, and Tailwind CSS. Supports i18n, dark mode, math equations, code highlighting, and more.",
    "type": "module",
    "scripts": {
        "dev": "astro dev",
        "dev:node": "NODE_OPTIONS='' astro dev",
        "build": "astro build && pagefind --site dist",
        "build:node": "NODE_OPTIONS='' astro build && pagefind --site dist",
        "build:tikz": "tsx scripts/render-tikz.ts",
        "preview": "astro preview",
        "astro": "astro",
        "format": "prettier --write '**/*.{js,jsx,ts,tsx,json,css,html,astro,mdx,md}'",
        "format:check": "prettier --check '**/*.{js,jsx,ts,tsx,json,css,html,astro,mdx,md}'",
        "type-check": "tsc --noEmit",
        "lint": "astro check",
        "clean": "rm -rf dist node_modules .astro",
        "reinstall": "bun run clean && bun install"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/WayneXuCN/academic-blog.git"
    },
    "keywords": [
        "astro",
        "astro-theme",
        "blog",
        "academic-blog",
        "tailwindcss",
        "react",
        "i18n",
        "dark-mode",
        "static-site",
        "markdown",
        "mdx",
        "katex",
        "mermaid"
    ],
    "author": "Wenjie Xu <wenjie.xu.cn@outlook.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/WayneXuCN/academic-blog/issues"
    },
    "homepage": "https://github.com/WayneXuCN/academic-blog#readme",
    "devDependencies": {
        "@astrojs/mdx": "^4.3.0",
        "@astrojs/react": "^4.4.2",
        "@astrojs/sitemap": "^3.3.0",
        "@astrojs/tailwind": "^6.0.2",
        "@tailwindcss/typography": "^0.5.19",
        "@types/leaflet": "^1.9.21",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "autoprefixer": "^10.4.22",
        "node-tikzjax": "^1.0.3",
        "pagefind": "^1.3.0",
        "postcss": "^8.5.6",
        "prettier": "^3.6.2",
        "prettier-plugin-astro": "^0.14.1",
        "tailwindcss": "^3.4.18",
        "tsx": "^4.19.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@astrojs/check": "^0.9.6",
        "@astrojs/rss": "^4.0.11",
        "@giscus/react": "^3.1.0",
        "@pagefind/default-ui": "^1.3.0",
        "astro": "^5.16.0",
        "chart.js": "^4.5.0",
        "diff2html": "^3.4.52",
        "echarts": "^6.0.0",
        "leaflet": "^1.9.4",
        "mermaid": "^11.4.0",
        "photoswipe": "^5.4.4",
        "plotly.js-dist-min": "^3.3.0",
        "prop-types": "^15.8.1",
        "react": "^19.2.0",
        "react-chartjs-2": "^5.3.0",
        "react-dom": "^19.2.0",
        "rehype-autolink-headings": "^7.1.0",
        "rehype-katex": "^7.0.1",
        "rehype-slug": "^6.0.0",
        "remark-github-beta-blockquote-admonitions": "^3.1.1",
        "remark-math": "^6.0.0",
        "swiper": "^12.0.3",
        "vega": "^6.2.0",
        "vega-embed": "^7.1.0",
        "vega-lite": "^6.4.1"
    }
}
