---
/**
 * /index.astro - 根路径首页
 * 直接渲染中文博客首页内容
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeLayout from '../components/layouts/HomeLayout.astro';
import Pagination from '../components/blog/Pagination.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../config';

const currentLang = 'zh';

// 获取中文所有文章
const allPosts = await getCollection('blog', ({ data }) => {
  return data.lang === currentLang;
});

// 按发布日期排序
const sortedPosts = allPosts.sort((a, b) => 
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

// 分页
const postsPerPage = siteConfig.home.postsPerPage;
const totalPages = Math.ceil(sortedPosts.length / postsPerPage);
const currentPage = 1;
const paginatedPosts = sortedPosts.slice(0, postsPerPage);

// 精选文章
const featuredPosts = sortedPosts.filter(post => post.data.featured);

// 页面信息
const siteTitle = siteConfig.title.zh;
const description = siteConfig.description.zh;
---

<BaseLayout 
  title={siteTitle}
  description={description}
  lang={currentLang}
>
  <main class="max-w-6xl mx-auto px-4 py-8">
    <HomeLayout 
      posts={paginatedPosts}
      featuredPosts={featuredPosts}
      lang={currentLang}
    />
    
    {totalPages > 1 && (
      <Pagination 
        currentPage={currentPage}
        totalPages={totalPages}
        baseUrl={`/${currentLang}/blog/page/`}
        lang={currentLang}
      />
    )}
  </main>
</BaseLayout>
