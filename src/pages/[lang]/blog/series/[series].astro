---
/**
 * 系列文章页面
 * 路由: /[lang]/blog/series/[series]
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostCard from '../../../../components/blog/PostCard.astro';
import { getCollection, getEntry } from 'astro:content';
import { siteConfig, getPostUrl } from '../../../../config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  // 收集所有系列
  const seriesByLang = {
    zh: new Set<string>(),
    en: new Set<string>(),
  };
  
  posts.forEach(post => {
    if (post.data.series) {
      seriesByLang[post.data.lang as 'zh' | 'en'].add(post.data.series);
    }
  });
  
  const paths = [];
  
  for (const lang of ['zh', 'en'] as const) {
    for (const series of seriesByLang[lang]) {
      paths.push({
        params: { lang, series },
      });
    }
  }
  
  return paths;
}

const { lang, series } = Astro.params;
const currentLang = lang as 'zh' | 'en';

// 尝试获取系列元数据
let seriesMeta;
try {
  seriesMeta = await getEntry('series', `${currentLang}/${series}`);
} catch {
  // 系列元数据可能不存在
}

const seriesTitle = seriesMeta?.data.title || series;
const seriesDescription = seriesMeta?.data.description;

// 获取该系列的所有文章
const allPosts = await getCollection('blog', ({ data }) => {
  return data.lang === currentLang && data.series === series;
});

// 按系列顺序排序
const sortedPosts = allPosts.sort((a, b) => {
  const orderA = a.data.seriesOrder || 999;
  const orderB = b.data.seriesOrder || 999;
  if (orderA !== orderB) return orderA - orderB;
  return new Date(a.data.pubDate).getTime() - new Date(b.data.pubDate).getTime();
});

// 页面信息
const siteTitle = currentLang === 'zh' ? siteConfig.title.zh : siteConfig.title.en;
const description = seriesDescription || (currentLang === 'zh'
  ? `${seriesTitle}系列的所有文章`
  : `All posts in the "${seriesTitle}" series`);
---

<BaseLayout 
  title={`${seriesTitle} - ${siteTitle}`}
  description={description}
  lang={currentLang}
>
  <main class="max-w-4xl mx-auto px-4 py-8">
    <header class="mb-12">
      <div class="inline-flex items-center gap-2 text-sm text-primary-600 dark:text-primary-400 mb-2">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        {currentLang === 'zh' ? '系列文章' : 'Series'}
      </div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">
        {seriesTitle}
      </h1>
      {seriesDescription && (
        <p class="text-gray-600 dark:text-gray-400 text-lg">
          {seriesDescription}
        </p>
      )}
      <div class="mt-4 text-sm text-gray-500">
        {currentLang === 'zh' 
          ? `共 ${sortedPosts.length} 篇文章` 
          : `${sortedPosts.length} posts`}
      </div>
    </header>
    
    {sortedPosts.length > 0 ? (
      <div class="space-y-4">
        {sortedPosts.map((post, index) => {
          const year = new Date(post.data.pubDate).getFullYear();
          // 从 post.id 提取 slug
          const slug = post.id.includes('/') ? post.id.split('/').pop()! : post.id;
          return (
            <a
              href={getPostUrl(slug, currentLang, year)}
              class="series-item flex items-start gap-4 p-4 rounded-lg bg-gray-50 dark:bg-gray-800/50 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
            >
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400 flex items-center justify-center font-medium text-sm">
                {index + 1}
              </div>
              <div class="flex-1 min-w-0">
                <h2 class="font-medium text-gray-900 dark:text-gray-100 mb-1">
                  {post.data.title}
                </h2>
                {post.data.description && (
                  <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
                    {post.data.description}
                  </p>
                )}
                <div class="mt-2 text-xs text-gray-500">
                  {new Date(post.data.pubDate).toLocaleDateString(
                    currentLang === 'zh' ? 'zh-CN' : 'en-US',
                    { year: 'numeric', month: 'short', day: 'numeric' }
                  )}
                </div>
              </div>
              <svg class="flex-shrink-0 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-16">
        <div class="text-6xl mb-4">📚</div>
        <p class="text-gray-500 dark:text-gray-400">
          {currentLang === 'zh' 
            ? '该系列暂无文章' 
            : 'No posts in this series yet'}
        </p>
      </div>
    )}
  </main>
</BaseLayout>
