---
/**
 * 分类页面
 * 路由: /[lang]/blog/category/[category]
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostCard from '../../../../components/blog/PostCard.astro';
import Pagination from '../../../../components/blog/Pagination.astro';
import { getCollection } from 'astro:content';
import { getSiteConfig, getCategoryConfig } from '../../../../utils/config';

export async function getStaticPaths() {
  const paths = [];
  const siteConfig = await getSiteConfig();
  const categories = Object.keys(siteConfig.categories);
  
  for (const lang of ['zh', 'en'] as const) {
    for (const category of categories) {
      paths.push({
        params: { lang, category },
      });
    }
  }
  
  return paths;
}

const { lang, category } = Astro.params;
const currentLang = lang as 'zh' | 'en';
const currentCategory = category as string;

// 获取配置
const siteConfig = await getSiteConfig();

// 获取分类配置
const categoryConfig = await getCategoryConfig(currentCategory);
const categoryName = currentLang === 'zh' 
  ? categoryConfig.name.zh 
  : categoryConfig.name.en;

// 获取该分类的所有文章
const allPosts = await getCollection('blog', ({ data }) => {
  return data.lang === currentLang && data.category === currentCategory;
});

// 按发布日期排序
const sortedPosts = allPosts.sort((a, b) => 
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

// 分页
const postsPerPage = 12;
const totalPages = Math.ceil(sortedPosts.length / postsPerPage);
const currentPage = 1;
const paginatedPosts = sortedPosts.slice(0, postsPerPage);

// 页面信息
const siteTitle = currentLang === 'zh' ? siteConfig.title.zh : siteConfig.title.en;
const description = currentLang === 'zh'
  ? `${categoryName}分类下的所有文章`
  : `All posts in ${categoryName} category`;
---

<BaseLayout 
  title={`${categoryName} - ${siteTitle}`}
  description={description}
  lang={currentLang}
>
  <main class="max-w-6xl mx-auto px-4 py-8">
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-2xl">{categoryConfig.icon}</span>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">
          {categoryName}
        </h1>
      </div>
      <p class="text-gray-600 dark:text-gray-400">
        {currentLang === 'zh' 
          ? `共 ${allPosts.length} 篇文章` 
          : `${allPosts.length} posts`}
      </p>
    </header>
    
    {sortedPosts.length > 0 ? (
      <>
        <!-- 混排网格：有图的大卡片，无图的紧凑横向布局 -->
        <div class="space-y-6 mb-8">
          {paginatedPosts.map((post) => (
            <PostCard post={post} lang={currentLang} />
          ))}
        </div>
        
        {totalPages > 1 && (
          <Pagination 
            currentPage={currentPage}
            totalPages={totalPages}
            baseUrl={`/${lang}/blog/category/${category}/page/`}
            lang={currentLang}
          />
        )}
      </>
    ) : (
      <div class="text-center py-16">
        <div class="text-6xl mb-4">📭</div>
        <p class="text-gray-500 dark:text-gray-400">
          {currentLang === 'zh' 
            ? '该分类下暂无文章' 
            : 'No posts in this category yet'}
        </p>
      </div>
    )}
  </main>
</BaseLayout>
