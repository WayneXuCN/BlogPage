---
/**
 * 博客列表页
 * 路由: /[lang]/blog/
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HomeLayout from '../../../components/layouts/HomeLayout.astro';
import Pagination from '../../../components/blog/Pagination.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { getSiteConfig } from '../../../utils/config';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;
const currentLang = lang as 'zh' | 'en';

// 获取配置
const siteConfig = await getSiteConfig();

// 获取当前语言的所有文章
const allPosts = await getCollection('blog', ({ data }: { data: CollectionEntry<'blog'>['data'] }) => {
  return data.lang === currentLang;
});

// 按发布日期排序
const sortedPosts = allPosts.sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

// 分页
const postsPerPage = siteConfig.home.postsPerPage;
const totalPages = Math.ceil(sortedPosts.length / postsPerPage);
const currentPage = 1;
const paginatedPosts = sortedPosts.slice(0, postsPerPage);

// 精选文章
const featuredPosts = sortedPosts.filter((post: CollectionEntry<'blog'>) => post.data.featured);

// 页面信息
const siteTitle = currentLang === 'zh' ? siteConfig.title.zh : siteConfig.title.en;
const description = currentLang === 'zh' ? siteConfig.description.zh : siteConfig.description.en;
---

<BaseLayout title={siteTitle} description={description} lang={currentLang}>
  <main class='max-w-6xl mx-auto px-4 py-8'>
    <HomeLayout posts={paginatedPosts} featuredPosts={featuredPosts} lang={currentLang} />

    {
      totalPages > 1 && (
        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          baseUrl={`/${lang}/blog/page/`}
          lang={currentLang}
        />
      )
    }
  </main>
</BaseLayout>
