---
/**
 * 分类总览页
 * 路由: /[lang]/blog/categories/
 * 显示所有分类和标签
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { siteConfig, getAllCategories, getCategoryUrl, getTagUrl } from '../../../../config';

export function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const currentLang = lang as 'zh' | 'en';

// 获取所有文章
const allPosts = await getCollection('blog', ({ data }) => data.lang === currentLang);

// 统计分类
const categoryCounts = allPosts.reduce((acc, post) => {
  const cat = post.data.category;
  acc[cat] = (acc[cat] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

// 统计标签
const tagCounts = allPosts.reduce((acc, post) => {
  (post.data.tags || []).forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

// 按数量排序标签
const sortedTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1]);

const categories = getAllCategories();

const i18n = {
  zh: {
    title: '分类与标签',
    categories: '文章分类',
    tags: '热门标签',
    posts: '篇文章',
    allTags: '全部标签',
  },
  en: {
    title: 'Categories & Tags',
    categories: 'Categories',
    tags: 'Popular Tags',
    posts: 'posts',
    allTags: 'All Tags',
  },
};

const t = i18n[currentLang];

// 分类颜色映射
const colorClasses: Record<string, { bg: string; border: string; text: string }> = {
  blue: { 
    bg: 'bg-blue-50 dark:bg-blue-900/20', 
    border: 'border-blue-200 dark:border-blue-800 hover:border-blue-400',
    text: 'text-blue-700 dark:text-blue-300'
  },
  green: { 
    bg: 'bg-green-50 dark:bg-green-900/20', 
    border: 'border-green-200 dark:border-green-800 hover:border-green-400',
    text: 'text-green-700 dark:text-green-300'
  },
  purple: { 
    bg: 'bg-purple-50 dark:bg-purple-900/20', 
    border: 'border-purple-200 dark:border-purple-800 hover:border-purple-400',
    text: 'text-purple-700 dark:text-purple-300'
  },
  orange: { 
    bg: 'bg-orange-50 dark:bg-orange-900/20', 
    border: 'border-orange-200 dark:border-orange-800 hover:border-orange-400',
    text: 'text-orange-700 dark:text-orange-300'
  },
  pink: { 
    bg: 'bg-pink-50 dark:bg-pink-900/20', 
    border: 'border-pink-200 dark:border-pink-800 hover:border-pink-400',
    text: 'text-pink-700 dark:text-pink-300'
  },
};
---

<BaseLayout 
  title={`${t.title} - ${currentLang === 'zh' ? siteConfig.title.zh : siteConfig.title.en}`}
  description={currentLang === 'zh' ? siteConfig.description.zh : siteConfig.description.en}
  lang={currentLang}
>
  <div class="max-w-4xl mx-auto">
    <!-- 页面标题 -->
    <header class="mb-12 text-center">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        {t.title}
      </h1>
      <p class="text-gray-600 dark:text-gray-400">
        {allPosts.length} {t.posts} · {sortedTags.length} {currentLang === 'zh' ? '个标签' : 'tags'}
      </p>
    </header>
    
    <!-- 分类区域 -->
    <section class="mb-16">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-3">
        <span class="w-1 h-6 bg-blue-500 rounded-full" />
        {t.categories}
      </h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {categories.map(cat => {
          const count = categoryCounts[cat.key] || 0;
          const colors = colorClasses[cat.color] || colorClasses.blue;
          
          return (
            <a
              href={getCategoryUrl(cat.key, currentLang)}
              class={`group flex items-start gap-4 p-5 rounded-2xl border-2 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 ${colors.bg} ${colors.border}`}
            >
              <span class="text-4xl">{cat.icon}</span>
              <div class="flex-1 min-w-0">
                <h3 class={`font-bold mb-1 ${colors.text}`}>
                  {currentLang === 'zh' ? cat.name.zh : cat.name.en}
                </h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-2">
                  {currentLang === 'zh' ? cat.description.zh : cat.description.en}
                </p>
                <span class="text-xs text-gray-500 dark:text-gray-500">
                  {count} {t.posts}
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
    
    <!-- 标签云区域 -->
    <section>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-3">
        <span class="w-1 h-6 bg-purple-500 rounded-full" />
        {t.tags}
      </h2>
      
      <div class="flex flex-wrap gap-2">
        {sortedTags.map(([tag, count]) => {
          // 根据数量计算大小
          const size = count >= 5 ? 'text-lg px-4 py-2' : count >= 3 ? 'text-base px-3 py-1.5' : 'text-sm px-2.5 py-1';
          const opacity = count >= 5 ? 'opacity-100' : count >= 3 ? 'opacity-90' : 'opacity-75';
          
          return (
            <a
              href={getTagUrl(tag, currentLang)}
              class={`inline-flex items-center gap-1.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900/30 hover:text-blue-700 dark:hover:text-blue-300 transition-all ${size} ${opacity}`}
            >
              <span class="text-gray-400 dark:text-gray-500">#</span>
              {tag}
              <span class="text-xs text-gray-400 dark:text-gray-500">({count})</span>
            </a>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>
