---
/**
 * /zh/about - 中文关于页面
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSiteConfig } from '../../utils/config';
import { getCollection, render } from 'astro:content';

const lang = 'zh' as const;

// 获取配置
const siteConfig = await getSiteConfig();

// 获取关于页面内容
const aboutPages = await getCollection('pages', (entry) => entry.id.startsWith('about/'));
const aboutPage = aboutPages.find((page) => page.data.lang === lang);
const { Content } = aboutPage ? await render(aboutPage) : { Content: null };

// 定义社交链接类型
interface SocialLink {
  platform: string;
  url: string;
  icon: string;
}
const socialLinks: SocialLink[] = siteConfig.social || [];
---

<BaseLayout
  title={`${aboutPage?.data.title || '关于'} | ${siteConfig.title.zh}`}
  description={aboutPage?.data.description || '关于徐文杰 - 学术研究者'}
  lang={lang}
>
  <div class='max-w-3xl mx-auto'>
    <!-- 个人信息 -->
    <section class='text-center mb-16'>
      <img
        src={siteConfig.authorInfo.avatar}
        alt={siteConfig.author.zh}
        class='w-32 h-32 rounded-full mx-auto mb-6 shadow-lg ring-4 ring-white dark:ring-gray-800'
      />
      <h1 class='text-3xl font-bold text-gray-900 dark:text-white mb-2'>
        {siteConfig.author.zh}
      </h1>
      <p class='text-gray-600 dark:text-gray-400 text-lg'>
        {aboutPage?.data.subtitle || '博士研究生 · 研究员'}
      </p>

      <!-- 社交链接 -->
      <div class='flex justify-center gap-4 mt-6'>
        {
          socialLinks.map((link) => (
            <a
              href={link.url}
              target='_blank'
              rel='noopener noreferrer'
              class='w-10 h-10 flex items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white transition-all'
              title={link.platform}
            >
              <i class={`${link.icon} text-lg`} />
            </a>
          ))
        }
      </div>
    </section>

    <!-- 内容区域 -->
    <section class='prose prose-lg dark:prose-invert max-w-none'>
      {Content ? <Content /> : (
        <>
          <h2>关于我</h2>
          <p>你好！我是徐文杰</p>
          <h2>联系我</h2>
          <p>
            欢迎通过邮件联系我：
            <a href={`mailto:${siteConfig.authorInfo.email}`}>{siteConfig.authorInfo.email}</a>
            ，或通过上方的社交平台与我交流。
          </p>
        </>
      )}
    </section>
  </div>
</BaseLayout>
