---
/**
 * Video.astro
 * 视频嵌入组件
 *
 * 支持本地视频、YouTube、Bilibili 等
 *
 * 用法：
 * <Video src="/videos/demo.mp4" caption="演示视频" />
 * <Video youtube="dQw4w9WgXcQ" caption="YouTube 视频" />
 * <Video bilibili="BV1xx411c7mD" caption="Bilibili 视频" />
 */
interface Props {
  /** 本地视频路径 */
  src?: string;
  /** YouTube 视频 ID */
  youtube?: string;
  /** Bilibili 视频 BV 号 */
  bilibili?: string;
  /** 视频标题/说明 */
  caption?: string;
  /** 封面图片 */
  poster?: string;
  /** 宽高比 */
  aspectRatio?: '16/9' | '4/3' | '1/1' | '9/16';
  /** 自动播放 */
  autoplay?: boolean;
  /** 循环播放 */
  loop?: boolean;
  /** 静音 */
  muted?: boolean;
  /** 显示控制条 */
  controls?: boolean;
  /** 自定义类名 */
  class?: string;
}

const {
  src,
  youtube,
  bilibili,
  caption,
  poster,
  aspectRatio = '16/9',
  autoplay = false,
  loop = false,
  muted = false,
  controls = true,
  class: className = '',
} = Astro.props;

// 构建嵌入 URL
let embedUrl = '';
let embedType: 'local' | 'youtube' | 'bilibili' | null = null;

if (src) {
  embedType = 'local';
} else if (youtube) {
  embedType = 'youtube';
  const params = new URLSearchParams();
  if (autoplay) params.set('autoplay', '1');
  if (loop) params.set('loop', '1');
  if (muted) params.set('mute', '1');
  params.set('rel', '0');
  embedUrl = `https://www.youtube-nocookie.com/embed/${youtube}?${params.toString()}`;
} else if (bilibili) {
  embedType = 'bilibili';
  const params = new URLSearchParams();
  if (autoplay) params.set('autoplay', '1');
  params.set('high_quality', '1');
  params.set('danmaku', '0');
  embedUrl = `https://player.bilibili.com/player.html?bvid=${bilibili}&${params.toString()}`;
}
---

<figure class:list={['video-container my-8', className]}>
  <div
    class='video-wrapper relative w-full bg-black rounded-lg overflow-hidden shadow-lg'
    style={`aspect-ratio: ${aspectRatio};`}
  >
    {
      embedType === 'local' && src && (
        <video
          src={src}
          poster={poster}
          autoplay={autoplay}
          loop={loop}
          muted={muted}
          controls={controls}
          playsinline
          class='w-full h-full object-contain'
        >
          <track kind='captions' src='' label='字幕' />
          您的浏览器不支持视频播放
        </video>
      )
    }

    {
      embedType === 'youtube' && (
        <iframe
          src={embedUrl}
          title={caption || 'YouTube video'}
          allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
          allowfullscreen
          loading='lazy'
          class='absolute inset-0 w-full h-full border-0'
        />
      )
    }

    {
      embedType === 'bilibili' && (
        <iframe
          src={embedUrl}
          title={caption || 'Bilibili video'}
          allowfullscreen
          loading='lazy'
          scrolling='no'
          class='absolute inset-0 w-full h-full border-0'
        />
      )
    }

    {
      !embedType && (
        <div class='flex items-center justify-center h-full text-gray-400'>请提供视频源</div>
      )
    }
  </div>

  {
    caption && (
      <figcaption class='mt-3 text-center text-sm text-gray-600 dark:text-gray-400 italic'>
        {caption}
      </figcaption>
    )
  }
</figure>

<style>
  .video-wrapper {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  }

  /* 视频播放器样式优化 */
  video::-webkit-media-controls-panel {
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  }
</style>
