---
/**
 * Pseudocode.astro
 * 伪代码渲染组件，使用 pseudocode.js
 *
 * 用法（属性方式）：
 * <Pseudocode
 *   code={`
 *     \\begin{algorithm}
 *     \\caption{Quicksort}
 *     \\begin{algorithmic}
 *     \\PROCEDURE{Quicksort}{$$A, p, r$$}
 *       \\IF{$$p < r$$}
 *         \\STATE $$q = $$ \\CALL{Partition}{$$A, p, r$$}
 *       \\ENDIF
 *     \\ENDPROCEDURE
 *     \\end{algorithmic}
 *     \\end{algorithm}
 *   `}
 *   caption="快速排序算法"
 * />
 *
 * 用法（children 方式）：
 * <Pseudocode title="快速排序">
 * {`\\begin{algorithm}...`}
 * </Pseudocode>
 */
interface Props {
  /** 伪代码内容（LaTeX 算法格式） */
  code?: string;
  /** 说明文字 */
  caption?: string;
  /** 标题（别名） */
  title?: string;
  /** 自定义类名 */
  class?: string;
}

const { code: codeProp, caption, title, class: className = '' } = Astro.props;

// 获取 slot 内容作为代码
const slotContent = await Astro.slots.render('default');
// 清理 HTML 标签和实体
const cleanedSlot = slotContent
  ?.replace(/<[^>]*>/g, '') // 移除 HTML 标签
  ?.replace(/&lt;/g, '<')
  ?.replace(/&gt;/g, '>')
  ?.replace(/&amp;/g, '&')
  ?.replace(/&quot;/g, '"')
  ?.replace(/&#39;/g, "'")
  ?.trim();

// 优先使用属性中的 code，否则使用 slot 内容
const code = codeProp || cleanedSlot || '';

// caption 或 title 均可
const displayCaption = caption || title;

// 生成唯一ID
const id = `pseudocode-${Math.random().toString(36).slice(2, 9)}`;

// 使用 Base64 编码来安全传递代码内容
const encodedCode = Buffer.from(code).toString('base64');
---

<figure class:list={['pseudocode-container my-8', className]}>
  <div
    id={id}
    class="pseudocode-wrapper bg-white dark:bg-gray-800 rounded-lg p-6 shadow-sm border border-gray-200 dark:border-gray-700 overflow-x-auto"
    data-code-base64={encodedCode}
  >
    <!-- 加载占位 -->
    <div class="pseudocode-loading flex items-center justify-center py-8 text-gray-400">
      <svg class="animate-spin h-8 w-8" viewBox="0 0 24 24">
        <circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"
          fill="none"></circle>
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        ></path>
      </svg>
    </div>
  </div>
  {
    displayCaption && (
      <figcaption class="mt-3 text-center text-sm text-gray-600 dark:text-gray-400 italic">
        {displayCaption}
      </figcaption>
    )
  }
</figure>

<script>
  // 动态加载 pseudocode.js
  let pseudocodeLoaded = false;

  async function loadPseudocode(): Promise<any> {
    if (pseudocodeLoaded) {
      return (window as any).pseudocode;
    }

    // 加载 KaTeX（pseudocode.js 依赖）
    if (!(window as any).katex) {
      await new Promise<void>((resolve, reject) => {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css';
        document.head.appendChild(link);

        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js';
        script.onload = () => resolve();
        script.onerror = reject;
        document.head.appendChild(script);
      });
    }

    // 加载 pseudocode.js
    await new Promise<void>((resolve, reject) => {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://cdn.jsdelivr.net/npm/pseudocode@2.4.1/build/pseudocode.min.css';
      document.head.appendChild(link);

      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/pseudocode@2.4.1/build/pseudocode.min.js';
      script.onload = () => resolve();
      script.onerror = reject;
      document.head.appendChild(script);
    });

    pseudocodeLoaded = true;
    return (window as any).pseudocode;
  }

  async function renderPseudocode(container: HTMLElement) {
    const encodedCode = container.dataset.codeBase64;
    if (!encodedCode || container.dataset.initialized === 'true') return;

    // 解码 Base64
    const code = atob(encodedCode);

    try {
      const pseudocode = await loadPseudocode();

      // 移除加载占位
      const loading = container.querySelector('.pseudocode-loading');
      if (loading) loading.remove();

      // 使用 renderToString 渲染伪代码为 HTML
      const htmlOutput = pseudocode.renderToString(code, {
        lineNumber: true,
        noEnd: false,
      });

      // 创建渲染容器并插入 HTML
      const renderTarget = document.createElement('div');
      renderTarget.className = 'pseudocode-output';
      renderTarget.innerHTML = htmlOutput;
      container.appendChild(renderTarget);

      container.dataset.initialized = 'true';

    } catch (error) {
      console.error('Pseudocode render error:', error);
      container.innerHTML = `
        <div class="text-amber-600 dark:text-amber-400 text-sm mb-2">⚠️ 伪代码渲染失败，显示源代码：</div>
        <pre class="bg-gray-100 dark:bg-gray-900 p-4 rounded text-xs overflow-x-auto"><code>${escapeHtml(code)}</code></pre>
      `;
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // 初始化所有伪代码
  function initAllPseudocode() {
    document.querySelectorAll<HTMLElement>('.pseudocode-wrapper[data-code-base64]').forEach(renderPseudocode);
  }

  // 页面加载后初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAllPseudocode);
  } else {
    initAllPseudocode();
  }

  // 支持 View Transitions
  document.addEventListener('astro:page-load', initAllPseudocode);
</script>

<style is:global>
  /* Pseudocode.js 自定义样式 */
  .pseudocode-wrapper .ps-root {
    font-family: 'Computer Modern', 'Latin Modern', serif;
  }

  .pseudocode-wrapper .ps-algorithm {
    border: none;
    margin: 0;
  }

  .pseudocode-wrapper .ps-algorithm > .ps-line:first-child {
    border-top: none;
  }

  .pseudocode-wrapper .ps-linenum {
    color: #999;
  }

  .dark .pseudocode-wrapper .ps-linenum {
    color: #666;
  }

  .dark .pseudocode-wrapper .ps-keyword {
    color: #ff7b72;
  }

  .dark .pseudocode-wrapper .ps-funcname {
    color: #d2a8ff;
  }

  .dark .pseudocode-wrapper .ps-comment {
    color: #8b949e;
  }

  .dark .pseudocode-wrapper {
    color: #c9d1d9;
  }

  .dark .pseudocode-wrapper .ps-algorithm {
    border-color: #30363d;
  }

  .dark .pseudocode-wrapper .ps-algorithm > .ps-line {
    border-color: #30363d;
  }

  /* KaTeX 数学公式样式 */
  .pseudocode-wrapper .katex {
    font-size: 1em;
  }
</style>
