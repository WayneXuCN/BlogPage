---
/**
 * PhotoGrid.astro
 * Bootstrap 风格响应式图片网格
 * 
 * 用法：
 * <PhotoGrid cols={3} gap={4}>
 *   <img src="/img1.jpg" alt="图片1" />
 *   <img src="/img2.jpg" alt="图片2" />
 *   <img src="/img3.jpg" alt="图片3" />
 * </PhotoGrid>
 */

interface Props {
  /** 列数 (1-4) */
  cols?: 1 | 2 | 3 | 4;
  /** 间距 (1-8) */
  gap?: 1 | 2 | 3 | 4 | 5 | 6 | 7 | 8;
  /** 是否启用灯箱效果 */
  lightbox?: boolean;
  /** 标题 */
  caption?: string;
}

const { cols = 3, gap = 4, lightbox = false, caption } = Astro.props;

const gridCols = {
  1: 'grid-cols-1',
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4',
};

const gapClass = `gap-${gap}`;
---

<figure class="photo-grid my-8">
  <div class={`grid ${gridCols[cols]} ${gapClass}`}>
    <slot />
  </div>
  {caption && (
    <figcaption class="mt-4 text-center text-sm text-gray-600 dark:text-gray-400 italic">
      {caption}
    </figcaption>
  )}
</figure>

<style>
  .photo-grid :global(img) {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 0.5rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .photo-grid :global(img:hover) {
    transform: scale(1.02);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }
</style>
