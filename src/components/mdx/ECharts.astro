---
/**
 * ECharts.astro
 * Apache ECharts 图表组件
 *
 * 用法：
 * <ECharts
 *   config={{
 *     title: { text: '图表标题' },
 *     xAxis: { data: ['A', 'B', 'C'] },
 *     yAxis: {},
 *     series: [{ type: 'bar', data: [10, 20, 30] }]
 *   }}
 *   caption="图表说明"
 * />
 */
interface Props {
  /** ECharts 配置对象 */
  config?: Record<string, unknown>;
  /** ECharts 配置对象（别名） */
  option?: Record<string, unknown>;
  /** 图表说明 */
  caption?: string;
  /** 图表高度（支持数字或字符串如 "400px"） */
  height?: number | string;
  /** 自定义类名 */
  class?: string;
}

const { config: configProp, option, caption, height: heightProp = 400, class: className = '' } = Astro.props;

// 支持两种属性名
const config = configProp || option || {};
// 支持数字和字符串高度
const height = typeof heightProp === 'number' ? `${heightProp}px` : heightProp;

// 生成唯一ID
const id = `echarts-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class:list={['echarts-container my-8', className]}>
  <div
    id={id}
    class="echarts-chart w-full bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700"
    style={`height: ${height};`}
    data-config={JSON.stringify(config)}
  >
    <!-- 加载占位 -->
    <div class="echarts-loading flex items-center justify-center h-full text-gray-400">
      <svg class="animate-spin h-8 w-8" viewBox="0 0 24 24">
        <circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"
          fill="none"></circle>
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        ></path>
      </svg>
    </div>
  </div>
  {
    caption && (
      <figcaption class="mt-3 text-center text-sm text-gray-600 dark:text-gray-400 italic">
        {caption}
      </figcaption>
    )
  }
</figure>

<script>
  // 动态导入 ECharts 以减少初始 bundle 体积
  // 存储图表实例和清理函数
  const chartInstances = new Map<string, any>();
  const resizeObservers = new Map<string, ResizeObserver>();
  let themeObserver: MutationObserver | null = null;

  async function initChart(container: HTMLElement) {
    const configStr = container.dataset.config;
    if (!configStr || container.dataset.initialized === 'true') return;

    try {
      // 动态导入 ECharts
      const echarts = await import('echarts');
      const config = JSON.parse(configStr);
      
      // 移除加载占位
      const loading = container.querySelector('.echarts-loading');
      if (loading) loading.remove();

      // 判断当前主题
      const isDark = document.documentElement.classList.contains('dark');
      
      // 销毁已有实例
      cleanupChart(container.id);

      // 创建图表实例
      const chart = echarts.init(container, isDark ? 'dark' : undefined);
      chartInstances.set(container.id, chart);
      container.dataset.initialized = 'true';

      // 设置配置
      chart.setOption(config);

      // 响应式调整 - 存储 ResizeObserver 以便清理
      const resizeObserver = new ResizeObserver(() => {
        chart.resize();
      });
      resizeObserver.observe(container);
      resizeObservers.set(container.id, resizeObserver);

    } catch (error) {
      console.error('ECharts render error:', error);
      container.innerHTML = `<div class="flex items-center justify-center h-full text-red-500 text-sm">图表渲染失败</div>`;
    }
  }

  // 清理单个图表
  function cleanupChart(id: string) {
    const chart = chartInstances.get(id);
    if (chart) {
      chart.dispose();
      chartInstances.delete(id);
    }
    const observer = resizeObservers.get(id);
    if (observer) {
      observer.disconnect();
      resizeObservers.delete(id);
    }
  }

  // 清理所有图表
  function cleanupAllCharts() {
    chartInstances.forEach((chart, id) => {
      chart.dispose();
    });
    chartInstances.clear();
    resizeObservers.forEach((observer) => {
      observer.disconnect();
    });
    resizeObservers.clear();
  }

  // 主题切换时重新渲染
  async function handleThemeChange() {
    const echarts = await import('echarts');
    document.querySelectorAll<HTMLElement>('.echarts-chart[data-config]').forEach(container => {
      const chart = chartInstances.get(container.id);
      if (chart) {
        const configStr = container.dataset.config;
        if (configStr) {
          const config = JSON.parse(configStr);
          const isDark = document.documentElement.classList.contains('dark');
          chart.dispose();
          const newChart = echarts.init(container, isDark ? 'dark' : undefined);
          chartInstances.set(container.id, newChart);
          newChart.setOption(config);
        }
      }
    });
  }

  // 初始化所有图表
  function initAllCharts() {
    document.querySelectorAll<HTMLElement>('.echarts-chart[data-config]').forEach(initChart);
  }

  // 设置主题监听器（单例模式）
  function setupThemeObserver() {
    if (themeObserver) return;
    
    themeObserver = new MutationObserver(mutations => {
      mutations.forEach(mutation => {
        if (mutation.attributeName === 'class') {
          handleThemeChange();
        }
      });
    });

    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class'],
    });
  }

  // 页面卸载前清理（View Transitions）
  function handleBeforeSwap() {
    cleanupAllCharts();
  }

  // 初始化
  function init() {
    initAllCharts();
    setupThemeObserver();
  }

  // 页面加载后初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // 支持 View Transitions - 页面切换前清理
  document.addEventListener('astro:before-swap', handleBeforeSwap);
  // 支持 View Transitions - 新页面加载后初始化
  document.addEventListener('astro:page-load', init);
</script>
