---
/**
 * Proof.astro
 * 证明环境组件（学术风格）
 */

interface Props {
  title?: string;
}

const { title = '证明' } = Astro.props;
---

<div class="proof-block my-6 p-5 bg-gray-50 dark:bg-gray-800/50 rounded-lg border-l-4 border-gray-400">
  <div class="proof-header font-semibold text-gray-700 dark:text-gray-300 mb-2 italic">
    {title}
  </div>
  <div class="proof-content text-gray-800 dark:text-gray-200">
    <slot />
  </div>
  <div class="text-right mt-2 text-gray-600 dark:text-gray-400">∎</div>
</div>
