---
/**
 * Typograms.astro
 * Typograms ASCII 图形组件
 * 
 * 将 ASCII 文本艺术转换为 SVG 图形
 *
 * 用法（属性方式）：
 * <Typograms
 *   code={`
 *     +----+
 *     |    |---> My diagram!
 *     +----+
 *   `}
 *   caption="示意图"
 * />
 * 
 * 用法（子元素方式）：
 * <Typograms>
 * {`+----+
 * |    |---> My diagram!
 * +----+`}
 * </Typograms>
 */
interface Props {
  /** Typograms ASCII 代码 */
  code?: string;
  /** 图形说明 */
  caption?: string;
  /** 自定义类名 */
  class?: string;
}

const { code: codeProp, caption, class: className = '' } = Astro.props;

// 获取 slot 内容作为代码
const slotContent = await Astro.slots.render('default');
// 清理 HTML 标签和实体
const cleanedSlot = slotContent
  ?.replace(/<[^>]*>/g, '') // 移除 HTML 标签
  ?.replace(/&lt;/g, '<')
  ?.replace(/&gt;/g, '>')
  ?.replace(/&amp;/g, '&')
  ?.replace(/&quot;/g, '"')
  ?.trim();

// 优先使用属性中的 code，否则使用 slot 内容
const code = codeProp || cleanedSlot || '';

// 生成唯一ID
const id = `typogram-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class:list={['typograms-container my-8', className]}>
  <div
    id={id}
    class="typograms-chart flex justify-center items-center bg-white dark:bg-gray-800 rounded-lg p-6 shadow-sm border border-gray-200 dark:border-gray-700 overflow-x-auto"
    data-code={code.trim()}
  >
    <!-- 加载占位 -->
    <div class="typograms-loading text-gray-400">
      <svg class="animate-spin h-6 w-6" viewBox="0 0 24 24">
        <circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"
          fill="none"></circle>
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        ></path>
      </svg>
    </div>
  </div>
  {
    caption && (
      <figcaption class="mt-3 text-center text-sm text-gray-600 dark:text-gray-400 italic">
        {caption}
      </figcaption>
    )
  }
</figure>

<script>
  // 使用 CDN 加载 typograms - 改进版：添加清理逻辑
  let typogramsLoaded = false;
  let typogramsModule: any = null;
  let themeObserver: MutationObserver | null = null;

  async function loadTypograms() {
    if (typogramsLoaded) return typogramsModule;

    try {
      // 从 CDN 加载 typograms (使用 esm.run CDN)
      // 注意：建议将 typograms 添加到 package.json 依赖中以获得更好的缓存
      typogramsModule = await import('https://esm.run/typograms@0.5.1');
      typogramsLoaded = true;
      return typogramsModule;
    } catch (error) {
      console.error('Failed to load typograms:', error);
      return null;
    }
  }

  async function renderTypogram(container: HTMLElement) {
    const code = container.dataset.code;
    if (!code || container.dataset.initialized === 'true') return;

    try {
      const typograms = await loadTypograms();
      
      // 移除加载占位
      const loading = container.querySelector('.typograms-loading');
      if (loading) loading.remove();

      if (typograms?.render) {
        // 使用 typograms 渲染
        const svg = typograms.render(code);
        container.innerHTML = svg;
      } else {
        // 如果 typograms 无法加载，显示原始代码
        container.innerHTML = `<pre class="font-mono text-sm whitespace-pre text-gray-700 dark:text-gray-300">${escapeHtml(code)}</pre>`;
      }

      // 调整 SVG 的颜色以适应主题
      const svgEl = container.querySelector('svg');
      if (svgEl) {
        const isDark = document.documentElement.classList.contains('dark');
        // 设置 SVG 的 stroke 和 fill 颜色
        svgEl.style.setProperty('--typogram-stroke', isDark ? '#e5e7eb' : '#1f2937');
        svgEl.style.setProperty('--typogram-fill', isDark ? '#e5e7eb' : '#1f2937');
        // 遍历所有路径和文本元素设置颜色
        svgEl.querySelectorAll('path, line, polyline, polygon, rect, circle, ellipse').forEach((el: any) => {
          if (el.getAttribute('stroke') && el.getAttribute('stroke') !== 'none') {
            el.setAttribute('stroke', isDark ? '#e5e7eb' : '#1f2937');
          }
          if (el.getAttribute('fill') && el.getAttribute('fill') !== 'none' && el.getAttribute('fill') !== 'transparent') {
            el.setAttribute('fill', isDark ? '#e5e7eb' : '#1f2937');
          }
        });
        svgEl.querySelectorAll('text').forEach((el: any) => {
          el.setAttribute('fill', isDark ? '#e5e7eb' : '#1f2937');
        });
      }
      
      container.dataset.initialized = 'true';
    } catch (error) {
      console.error('Typogram render error:', error);
      // 显示原始代码作为后备
      const code = container.dataset.code || '';
      container.innerHTML = `<pre class="font-mono text-sm whitespace-pre text-gray-700 dark:text-gray-300">${escapeHtml(code)}</pre>`;
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // 主题切换处理
  function handleThemeChange() {
    const isDark = document.documentElement.classList.contains('dark');
    document.querySelectorAll<SVGElement>('.typograms-chart svg').forEach(svg => {
      // 设置 SVG 的 stroke 和 fill 颜色
      svg.querySelectorAll('path, line, polyline, polygon, rect, circle, ellipse').forEach((el: any) => {
        if (el.getAttribute('stroke') && el.getAttribute('stroke') !== 'none') {
          el.setAttribute('stroke', isDark ? '#e5e7eb' : '#1f2937');
        }
        if (el.getAttribute('fill') && el.getAttribute('fill') !== 'none' && el.getAttribute('fill') !== 'transparent') {
          el.setAttribute('fill', isDark ? '#e5e7eb' : '#1f2937');
        }
      });
      svg.querySelectorAll('text').forEach((el: any) => {
        el.setAttribute('fill', isDark ? '#e5e7eb' : '#1f2937');
      });
    });
  }

  // 初始化所有 typograms
  function initAllTypograms() {
    document.querySelectorAll<HTMLElement>('.typograms-chart[data-code]').forEach(renderTypogram);
  }

  // 设置主题监听器（单例模式）
  function setupThemeObserver() {
    if (themeObserver) return;
    
    themeObserver = new MutationObserver(mutations => {
      mutations.forEach(mutation => {
        if (mutation.attributeName === 'class') {
          handleThemeChange();
        }
      });
    });

    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class'],
    });
  }

  // 页面卸载前清理（View Transitions）
  function handleBeforeSwap() {
    // 重置初始化状态
    document.querySelectorAll<HTMLElement>('.typograms-chart[data-code]').forEach(container => {
      container.dataset.initialized = '';
    });
  }

  // 初始化
  function init() {
    initAllTypograms();
    setupThemeObserver();
  }

  // 页面加载后初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // 支持 View Transitions
  document.addEventListener('astro:before-swap', handleBeforeSwap);
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .typograms-chart :global(svg) {
    max-width: 100%;
    height: auto;
  }
</style>
