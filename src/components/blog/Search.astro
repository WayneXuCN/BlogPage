---
/**
 * Search.astro
 * Pagefind 搜索组件 - 修复版本，确保弹窗居中且功能正常
 */

interface Props {
  lang?: 'zh' | 'en';
}

const { lang = 'zh' } = Astro.props;

const i18n = {
  zh: {
    placeholder: '搜索文章...',
    tip: '输入关键词开始搜索',
    noResults: '未找到相关结果',
    loading: '搜索中...',
    select: '选择',
    navigate: '导航',
    close: '关闭',
  },
  en: {
    placeholder: 'Search posts...',
    tip: 'Type to search',
    noResults: 'No results found',
    loading: 'Searching...',
    select: 'Select',
    navigate: 'Navigate',
    close: 'Close',
  },
};

const t = i18n[lang];
---

<!-- 搜索按钮 - 使用 data 属性标识 -->
<button
  type='button'
  data-search-btn
  class='search-trigger-btn p-2 rounded-lg text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors cursor-pointer relative z-10'
  aria-label={t.placeholder}
  title={`${t.placeholder} (⌘K)`}
>
  <svg class='w-5 h-5 pointer-events-none' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
    <path
      stroke-linecap='round'
      stroke-linejoin='round'
      stroke-width='2'
      d='M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z'></path>
  </svg>
</button>

<!-- 搜索模态框 - 放在 body 末尾通过 portal 或高 z-index 确保显示 -->
<div
  data-search-modal
  class='search-modal fixed inset-0 hidden'
  role='dialog'
  aria-modal='true'
  aria-label={t.placeholder}
>
  <!-- 背景遮罩 -->
  <div data-search-backdrop class='search-backdrop absolute inset-0 bg-black/60 backdrop-blur-sm'></div>

  <!-- 对话框 - 固定在视口上方 -->
  <div
    class='search-dialog-wrapper relative z-10 w-full h-full flex justify-center items-start pt-[10vh] sm:pt-[15vh] px-4 pb-4'
  >
    <div
      class='search-dialog w-full max-w-2xl bg-white dark:bg-gray-800 rounded-2xl shadow-2xl flex flex-col max-h-[75vh] animate-fade-in-up overflow-hidden'
    >
      <!-- 搜索头部 -->
      <div
        class='flex items-center border-b border-gray-200 dark:border-gray-700 px-4 flex-shrink-0'
      >
        <svg
          class='w-5 h-5 text-gray-400 flex-shrink-0'
          fill='none'
          stroke='currentColor'
          viewBox='0 0 24 24'
        >
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z'></path>
        </svg>
        <input
          data-search-input
          type='text'
          placeholder={t.placeholder}
          class='flex-1 px-4 py-4 bg-transparent text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none text-lg'
          autocomplete='off'
        />
        <button
          type='button'
          data-search-close
          class='p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 flex-shrink-0 cursor-pointer'
          aria-label={t.close}
        >
          <kbd class='px-2 py-1 text-xs bg-gray-100 dark:bg-gray-700 rounded font-mono pointer-events-none'>ESC</kbd>
        </button>
      </div>

      <!-- 搜索结果容器 -->
      <div data-search-results class='flex-1 overflow-y-auto p-4 min-h-[100px]'>
        <p class='search-tip text-center text-gray-500 dark:text-gray-400 py-8'>
          {t.tip}
        </p>
      </div>

      <!-- 搜索底部 -->
      <div
        class='border-t border-gray-200 dark:border-gray-700 px-4 py-3 flex items-center justify-between text-xs text-gray-500 dark:text-gray-400 flex-shrink-0'
      >
        <div class='flex items-center gap-4'>
          <span class='flex items-center gap-1'>
            <kbd class='px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 rounded font-mono'>↵</kbd>
            {t.select}
          </span>
          <span class='flex items-center gap-1'>
            <kbd class='px-1.5 py-0.5 bg-gray-100 dark:bg-gray-700 rounded font-mono'>↑↓</kbd>
            {t.navigate}
          </span>
        </div>
        <span class='flex items-center gap-1.5'>
          <svg class='w-4 h-4' viewBox='0 0 24 24' fill='currentColor'>
            <path
              d='M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z'
            ></path>
          </svg>
          Pagefind
        </span>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ t: JSON.stringify(i18n[lang]) }}>
  const texts = JSON.parse(t);

  // Pagefind 搜索功能 - 使用全局变量避免重复加载
  let pagefindInstance = null;
  let isPagefindLoading = false;

  async function initPagefind() {
    if (pagefindInstance) return pagefindInstance;
    if (isPagefindLoading) {
      // 等待加载完成 - 使用 Promise 替代 setInterval 轮询
      return new Promise((resolve, reject) => {
        const maxWait = 10000; // 10秒超时
        const startTime = Date.now();
        
        const check = () => {
          if (pagefindInstance) {
            resolve(pagefindInstance);
          } else if (!isPagefindLoading) {
            resolve(null);
          } else if (Date.now() - startTime > maxWait) {
            reject(new Error('Pagefind loading timeout'));
          } else {
            requestAnimationFrame(check);
          }
        };
        check();
      });
    }

    isPagefindLoading = true;

    try {
      // 动态加载 Pagefind - 使用相对于站点根目录的路径
      // 在开发模式下，pagefind 可能不可用，需要优雅降级
      const basePath = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
      const pagefindUrl = `${basePath}/pagefind/pagefind.js`;
      
      // 检查文件是否存在（仅在非生产环境）
      if (import.meta.env.DEV) {
        try {
          const response = await fetch(pagefindUrl, { method: 'HEAD' });
          if (!response.ok) throw new Error('Pagefind not found');
        } catch (e) {
          console.warn('Pagefind index not found. Search will not work in dev mode unless you run `bun run build` first.');
          isPagefindLoading = false;
          return null;
        }
      }

      pagefindInstance = await import(/* @vite-ignore */ pagefindUrl);
      await pagefindInstance.init();
      isPagefindLoading = false;
      return pagefindInstance;
    } catch (e) {
      console.warn('Pagefind load error:', e);
      isPagefindLoading = false;
      return null;
    }
  }

  // 使用事件委托和 AbortController 管理事件
  let abortController = null;
  let searchTimeout = null;
  let currentIndex = 0;

  function openSearch() {
    const modal = document.querySelector('[data-search-modal]');
    const input = document.querySelector('[data-search-input]');
    if (!modal) return;
    
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    
    // 延迟聚焦以确保动画完成
    requestAnimationFrame(() => {
      setTimeout(() => input?.focus(), 50);
    });
    
    // 预加载 Pagefind
    initPagefind();
  }

  function closeSearch() {
    const modal = document.querySelector('[data-search-modal]');
    const input = document.querySelector('[data-search-input]');
    const results = document.querySelector('[data-search-results]');
    
    if (!modal) return;
    
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    
    if (input) input.value = '';
    if (results) {
      results.innerHTML = `<p class="search-tip text-center text-gray-500 dark:text-gray-400 py-8">${texts.tip}</p>`;
    }
    
    if (searchTimeout) {
      clearTimeout(searchTimeout);
      searchTimeout = null;
    }
    currentIndex = 0;
  }

  async function handleSearch(query) {
    const results = document.querySelector('[data-search-results]');
    if (!results) return;

    if (!query.trim()) {
      results.innerHTML = `<p class="search-tip text-center text-gray-500 dark:text-gray-400 py-8">${texts.tip}</p>`;
      return;
    }

    // 显示加载状态
    results.innerHTML = `<p class="text-center text-gray-500 dark:text-gray-400 py-8">${texts.loading}</p>`;

    const pf = await initPagefind();
    if (!pf) {
      results.innerHTML = `<p class="text-center text-amber-600 dark:text-amber-400 py-8">搜索功能需要先运行 build 命令生成索引</p>`;
      return;
    }

    try {
      const search = await pf.search(query);

      if (search.results.length === 0) {
        results.innerHTML = `<p class="text-center text-gray-500 dark:text-gray-400 py-8">${texts.noResults}</p>`;
        return;
      }

      // 获取结果详情
      const searchResults = await Promise.all(search.results.slice(0, 10).map(r => r.data()));

      results.innerHTML = searchResults
        .map((result, index) => `
          <a 
            href="${result.url}" 
            class="search-result-item block p-4 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors mb-2 ${index === 0 ? 'bg-gray-50 dark:bg-gray-700/50' : ''}"
            data-index="${index}"
          >
            <h3 class="font-semibold text-gray-900 dark:text-white mb-1 line-clamp-1">${result.meta?.title || 'Untitled'}</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2">${result.excerpt || ''}</p>
          </a>
        `)
        .join('');

      currentIndex = 0;
    } catch (err) {
      console.error('Search error:', err);
      results.innerHTML = `<p class="text-center text-red-500 dark:text-red-400 py-8">搜索出错，请重试</p>`;
    }
  }

  function handleKeyboardNavigation(e) {
    const results = document.querySelector('[data-search-results]');
    const items = results?.querySelectorAll('.search-result-item');
    if (!items || items.length === 0) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      currentIndex = (currentIndex + 1) % items.length;
      updateActiveItem(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      currentIndex = (currentIndex - 1 + items.length) % items.length;
      updateActiveItem(items);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      const activeItem = items[currentIndex];
      if (activeItem) {
        window.location.href = activeItem.getAttribute('href') || '';
      }
    }
  }

  function updateActiveItem(items) {
    items.forEach((item, i) => {
      item.classList.toggle('bg-gray-50', i === currentIndex);
      item.classList.toggle('dark:bg-gray-700/50', i === currentIndex);
    });
    items[currentIndex]?.scrollIntoView({ block: 'nearest' });
  }

  function initSearch() {
    // 清理旧的事件监听器
    if (abortController) {
      abortController.abort();
    }
    abortController = new AbortController();
    const { signal } = abortController;

    // 使用事件委托绑定到 document
    document.addEventListener('click', (e) => {
      const target = e.target;
      
      // 搜索按钮点击
      if (target.closest('[data-search-btn]')) {
        e.preventDefault();
        e.stopPropagation();
        openSearch();
        return;
      }
      
      // 关闭按钮点击
      if (target.closest('[data-search-close]')) {
        e.preventDefault();
        closeSearch();
        return;
      }
      
      // 背景遮罩点击
      if (target.closest('[data-search-backdrop]')) {
        closeSearch();
        return;
      }
    }, { signal });

    // 键盘快捷键
    document.addEventListener('keydown', (e) => {
      const modal = document.querySelector('[data-search-modal]');
      if (!modal) return;
      
      const isOpen = !modal.classList.contains('hidden');
      
      // ESC 关闭
      if (e.key === 'Escape' && isOpen) {
        closeSearch();
        return;
      }
      
      // Cmd/Ctrl + K 切换
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (isOpen) {
          closeSearch();
        } else {
          openSearch();
        }
        return;
      }
      
      // 键盘导航（仅在打开时）
      if (isOpen && ['ArrowDown', 'ArrowUp', 'Enter'].includes(e.key)) {
        handleKeyboardNavigation(e);
      }
    }, { signal });

    // 搜索输入
    document.addEventListener('input', (e) => {
      const target = e.target;
      if (!target.matches('[data-search-input]')) return;
      
      const query = target.value.trim();
      
      if (searchTimeout) clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => handleSearch(query), 200);
    }, { signal });
  }

  function cleanupSearch() {
    if (abortController) {
      abortController.abort();
      abortController = null;
    }
    if (searchTimeout) {
      clearTimeout(searchTimeout);
      searchTimeout = null;
    }
    // 确保模态框关闭
    const modal = document.querySelector('[data-search-modal]');
    if (modal && !modal.classList.contains('hidden')) {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }
  }

  // 初始化
  initSearch();
  
  // View Transitions 支持
  document.addEventListener('astro:before-swap', cleanupSearch);
  document.addEventListener('astro:page-load', initSearch);
</script>

<style>
  /* 搜索模态框 - 确保最高层级 */
  .search-modal {
    z-index: 99999;
    isolation: isolate;
  }
  
  /* 搜索按钮增强点击区域 */
  .search-trigger-btn {
    min-width: 40px;
    min-height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(-20px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.2s ease-out;
  }

  /* 搜索结果高亮 */
  .search-result-item mark {
    background-color: rgba(59, 130, 246, 0.3);
    color: inherit;
    padding: 0 2px;
    border-radius: 2px;
  }
  
  /* 移动端适配 */
  @media (max-width: 640px) {
    .search-dialog-wrapper {
      padding-top: 5vh;
    }
    
    .search-dialog {
      max-height: 85vh;
      border-radius: 1rem;
    }
  }
</style>
