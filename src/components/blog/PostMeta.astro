---
/**
 * PostMeta.astro
 * 文章元信息（日期、阅读时间、作者）
 */
import { formatDate } from '../../utils/config';

interface Props {
  pubDate: Date;
  updatedDate?: Date;
  readingTime: number;
  lang?: 'zh' | 'en';
  author?: string;
}

const { pubDate, updatedDate, readingTime, lang = 'zh', author } = Astro.props;

const i18n = {
  zh: {
    publishedOn: '发布于',
    updatedOn: '更新于',
    readingTime: '阅读时长',
    minutes: '分钟',
  },
  en: {
    publishedOn: 'Published',
    updatedOn: 'Updated',
    readingTime: 'Reading time',
    minutes: 'min read',
  },
};

const t = i18n[lang];
---

<div class='flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-600 dark:text-gray-400'>
  <!-- 作者 -->
  {
    author && (
      <span class='flex items-center gap-1.5'>
        <svg class='w-4 h-4' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z'
          />
        </svg>
        <span>{author}</span>
      </span>
    )
  }

  <!-- 发布日期 -->
  <span class='flex items-center gap-1.5'>
    <svg class='w-4 h-4' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
      <path
        stroke-linecap='round'
        stroke-linejoin='round'
        stroke-width='2'
        d='M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z'
      ></path>
    </svg>
    <time datetime={pubDate.toISOString()}>
      {formatDate(pubDate, lang)}
    </time>
  </span>

  <!-- 更新日期 -->
  {
    updatedDate && updatedDate > pubDate && (
      <span class='flex items-center gap-1.5 text-green-600 dark:text-green-400'>
        <svg class='w-4 h-4' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            stroke-width='2'
            d='M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15'
          />
        </svg>
        <span>
          {t.updatedOn} {formatDate(updatedDate, lang)}
        </span>
      </span>
    )
  }

  <!-- 阅读时间 -->
  <span class='flex items-center gap-1.5'>
    <svg class='w-4 h-4' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
      <path
        stroke-linecap='round'
        stroke-linejoin='round'
        stroke-width='2'
        d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'></path>
    </svg>
    <span>{readingTime} {t.minutes}</span>
  </span>
</div>
