---
/**
 * FeaturedCarousel.astro
 * 精选文章轮播图组件
 */
import type { CollectionEntry } from 'astro:content';
import { siteConfig, getPostUrl, formatDate } from '../../config';

interface Props {
  posts: CollectionEntry<'blog'>[];
  lang?: 'zh' | 'en';
  autoPlay?: boolean;
  interval?: number;
}

const { 
  posts, 
  lang = 'zh',
  autoPlay = siteConfig.home.carouselAutoPlay,
  interval = siteConfig.home.carouselInterval,
} = Astro.props;

function getSlug(post: CollectionEntry<'blog'>) {
  return post.id.includes('/') ? post.id.split('/').pop()! : post.id;
}

function getYear(post: CollectionEntry<'blog'>) {
  return new Date(post.data.pubDate).getFullYear();
}

const categoryConfig = (category: string) => siteConfig.categories[category as keyof typeof siteConfig.categories];

const i18n = {
  zh: { featured: '精选', minRead: '分钟' },
  en: { featured: 'Featured', minRead: 'min' },
};

const t = i18n[lang];
---

{posts.length > 0 && (
  <section class="featured-carousel relative" data-autoplay={autoPlay} data-interval={interval}>
    <div class="carousel-container relative rounded-2xl overflow-hidden bg-gray-900 aspect-[2/1] sm:aspect-[21/9] shadow-2xl">
      {posts.map((post, index) => {
        const cat = categoryConfig(post.data.category);
        const readingTime = Math.ceil((post.data.description?.length || 0) / 100) + 2;
        
        return (
          <div 
            class={`carousel-item absolute inset-0 transition-opacity duration-700 ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
            data-index={index}
          >
            <a href={getPostUrl(getSlug(post), lang, getYear(post))} class="block w-full h-full group">
              {post.data.image ? (
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-60 group-hover:scale-105 transition-all duration-700"
                />
              ) : (
                <div class="absolute inset-0 bg-gradient-to-br from-blue-600/30 via-purple-600/20 to-indigo-600/30" />
              )}
              
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/20" />
              
              <!-- 内容区域 -->
              <div class="absolute inset-0 p-4 sm:p-6 lg:p-10 flex flex-col justify-end">
                <div class="max-w-3xl">
                  <div class="flex flex-wrap items-center gap-2 mb-3">
                    {cat && (
                      <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-white/20 text-white backdrop-blur-sm">
                        {cat.icon} {lang === 'zh' ? cat.name.zh : cat.name.en}
                      </span>
                    )}
                    {post.data.featured && (
                      <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-500 text-black">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                        {t.featured}
                      </span>
                    )}
                  </div>
                  
                  <h2 class="text-lg sm:text-2xl lg:text-4xl font-bold text-white mb-2 sm:mb-3 leading-tight group-hover:text-blue-200 transition-colors line-clamp-2">
                    {post.data.title}
                  </h2>
                  
                  <p class="text-gray-300 text-sm lg:text-base line-clamp-2 mb-3 max-w-2xl hidden sm:block">
                    {post.data.description}
                  </p>
                  
                  <div class="flex items-center gap-3 text-xs sm:text-sm text-gray-400">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate, lang)}
                    </time>
                    <span class="w-1 h-1 rounded-full bg-gray-500" />
                    <span>{readingTime} {t.minRead}</span>
                  </div>
                </div>
              </div>
            </a>
          </div>
        );
      })}
      
      <!-- 右下角控制区 -->
      {posts.length > 1 && (
        <div class="absolute bottom-4 right-4 sm:bottom-6 sm:right-6 z-20 flex items-center gap-3 bg-black/40 backdrop-blur-md rounded-full px-3 py-2">
          <button class="carousel-prev p-1.5 rounded-full text-white/80 hover:text-white hover:bg-white/20 transition-colors" aria-label="上一张">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          
          <div class="carousel-indicators flex items-center gap-1.5">
            {posts.map((_, index) => (
              <button
                class={`indicator w-1.5 h-1.5 rounded-full transition-all ${index === 0 ? 'bg-white w-4' : 'bg-white/40 hover:bg-white/60'}`}
                data-index={index}
                aria-label={`第 ${index + 1} 张`}
              />
            ))}
          </div>
          
          <button class="carousel-next p-1.5 rounded-full text-white/80 hover:text-white hover:bg-white/20 transition-colors" aria-label="下一张">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      )}
    </div>
  </section>
)}

<script>
  function initCarousel() {
    const carousels = document.querySelectorAll('.featured-carousel');
    
    carousels.forEach(carousel => {
      if (carousel.hasAttribute('data-initialized')) return;
      carousel.setAttribute('data-initialized', 'true');
      
      const container = carousel.querySelector('.carousel-container');
      const items = carousel.querySelectorAll('.carousel-item');
      const indicators = carousel.querySelectorAll('.indicator');
      const prevBtn = carousel.querySelector('.carousel-prev');
      const nextBtn = carousel.querySelector('.carousel-next');
      
      if (!container || items.length <= 1) return;
      
      let currentIndex = 0;
      let autoPlayTimer: number | null = null;
      const autoPlay = carousel.getAttribute('data-autoplay') === 'true';
      const interval = parseInt(carousel.getAttribute('data-interval') || '5000', 10);
      
      function showSlide(index: number) {
        if (index < 0) index = items.length - 1;
        if (index >= items.length) index = 0;
        
        items.forEach((item, i) => {
          item.classList.toggle('opacity-100', i === index);
          item.classList.toggle('z-10', i === index);
          item.classList.toggle('opacity-0', i !== index);
          item.classList.toggle('z-0', i !== index);
        });
        
        indicators.forEach((ind, i) => {
          ind.classList.toggle('bg-white', i === index);
          ind.classList.toggle('w-4', i === index);
          ind.classList.toggle('bg-white/40', i !== index);
          ind.classList.toggle('w-1.5', i !== index);
        });
        
        currentIndex = index;
      }
      
      function nextSlide() { showSlide(currentIndex + 1); }
      function prevSlide() { showSlide(currentIndex - 1); }
      function startAutoPlay() { if (autoPlay && !autoPlayTimer) autoPlayTimer = window.setInterval(nextSlide, interval); }
      function stopAutoPlay() { if (autoPlayTimer) { clearInterval(autoPlayTimer); autoPlayTimer = null; } }
      
      [prevBtn, nextBtn].forEach((btn, i) => {
        if (!btn) return;
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          stopAutoPlay();
          i === 0 ? prevSlide() : nextSlide();
          startAutoPlay();
        });
      });
      
      indicators.forEach((ind, index) => {
        ind.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          stopAutoPlay();
          showSlide(index);
          startAutoPlay();
        });
      });
      
      container.addEventListener('mouseenter', stopAutoPlay);
      container.addEventListener('mouseleave', startAutoPlay);
      
      let touchStartX = 0;
      container.addEventListener('touchstart', (e) => { touchStartX = (e as TouchEvent).changedTouches[0].screenX; stopAutoPlay(); }, { passive: true });
      container.addEventListener('touchend', (e) => {
        const diff = touchStartX - (e as TouchEvent).changedTouches[0].screenX;
        if (Math.abs(diff) > 50) diff > 0 ? nextSlide() : prevSlide();
        startAutoPlay();
      }, { passive: true });
      
      startAutoPlay();
    });
  }
  
  initCarousel();
  document.addEventListener('astro:page-load', initCarousel);
</script>
