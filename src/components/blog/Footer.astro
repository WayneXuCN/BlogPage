---
/**
 * Footer.astro
 * 博客页脚
 */
import { getSiteConfig } from '../../utils/config';

interface Props {
  lang?: 'zh' | 'en';
}

const { lang = 'zh' } = Astro.props;

// 获取配置
const siteConfig = await getSiteConfig();

const currentYear = new Date().getFullYear();
const siteTitle = lang === 'zh' ? siteConfig.title.zh : siteConfig.title.en;
const siteDescription = lang === 'zh' ? siteConfig.description.zh : siteConfig.description.en;

// 多语言文案
const i18n = {
  zh: {
    copyright: `© ${currentYear} ${siteConfig.authorInfo.name}. 保留所有权利。`,
    poweredBy: '基于 Astro 构建',
    rss: 'RSS 订阅',
    theme: '主题切换',
  },
  en: {
    copyright: `© ${currentYear} ${siteConfig.authorInfo.name}. All rights reserved.`,
    poweredBy: 'Powered by Astro',
    rss: 'RSS Feed',
    theme: 'Toggle Theme',
  },
};

const t = i18n[lang];
---

<footer class='border-t border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/50'>
  <div class='container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl py-12'>
    <div class='grid grid-cols-1 md:grid-cols-3 gap-8'>
      <!-- 站点信息 -->
      <div class='space-y-4'>
        <h3 class='text-lg font-semibold text-gray-900 dark:text-white'>
          {siteTitle}
        </h3>
        <p class='text-sm text-gray-600 dark:text-gray-400 leading-relaxed'>
          {siteDescription}
        </p>
      </div>

      <!-- 快速链接 -->
      <div class='space-y-4'>
        <h3 class='text-lg font-semibold text-gray-900 dark:text-white'>
          {lang === 'zh' ? '快速链接' : 'Quick Links'}
        </h3>
        <ul class='space-y-2'>
          <li>
            <a
              href={`/${lang}/blog/categories/`}
              class='text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors'
            >
              {lang === 'zh' ? '分类标签' : 'Categories'}
            </a>
          </li>
          <li>
            <a
              href={`/${lang}/blog/archive/`}
              class='text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors'
            >
              {lang === 'zh' ? '文章归档' : 'Archive'}
            </a>
          </li>
          <li>
            <a
              href={`/${lang}/rss.xml`}
              class='text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors inline-flex items-center gap-1'
            >
              <svg class='w-4 h-4' fill='currentColor' viewBox='0 0 24 24'>
                <path
                  d='M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z'
                ></path>
              </svg>
              {t.rss}
            </a>
          </li>
        </ul>
      </div>

      <!-- 社交链接 -->
      <div class='space-y-4'>
        <h3 class='text-lg font-semibold text-gray-900 dark:text-white'>
          {lang === 'zh' ? '联系方式' : 'Connect'}
        </h3>
        <div class='flex space-x-4'>
          {
            siteConfig.social.map(link => (
              <a
                href={link.url}
                target='_blank'
                rel='noopener noreferrer'
                class='p-2 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors'
                aria-label={link.platform}
                title={link.platform}
              >
                <i class={`${link.icon} text-xl`} />
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- 底部版权 -->
    <div
      class='mt-12 pt-8 border-t border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4'
    >
      <p class='text-sm text-gray-600 dark:text-gray-400'>
        {t.copyright}
      </p>
      <p class='text-sm text-gray-500 dark:text-gray-500'>
        {t.poweredBy}
        <a
          href='https://astro.build'
          target='_blank'
          rel='noopener noreferrer'
          class='hover:text-gray-900 dark:hover:text-white transition-colors'
        >
          {' '}Astro
        </a>
      </p>
    </div>
  </div>
</footer>
